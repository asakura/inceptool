#! Suite 5: Redirects

# === Output ===

=== simple
echo foo > file.txt
---
(redirected (command (word "echo") (word "foo")) (redirect ">" (word "file.txt")))
---


=== simple no space before
echo foo> file.txt
---
(redirected (command (word "echo") (word "foo")) (redirect ">" (word "file.txt")))
---


=== simple no space after
echo foo >file.txt
---
(redirected (command (word "echo") (word "foo")) (redirect ">" (word "file.txt")))
---


=== simple no spaces
echo foo>file.txt
---
(redirected (command (word "echo") (word "foo")) (redirect ">" (word "file.txt")))
---


=== to dev null
whoami > /dev/null
---
(redirected (command (word "whoami")) (redirect ">" (word "/dev/null")))
---


=== simple quoted target
echo foo > "file with spaces.txt"
---
(redirected (command (word "echo") (word "foo")) (redirect ">" (word "\"file with spaces.txt\"")))
---


# === Append ===

=== simple
echo foo >> file.txt
---
(redirected (command (word "echo") (word "foo")) (redirect ">>" (word "file.txt")))
---


=== no spaces
echo foo>>file.txt
---
(redirected (command (word "echo") (word "foo")) (redirect ">>" (word "file.txt")))
---


=== to log
date >> /var/log/myapp.log
---
(redirected (command (word "date")) (redirect ">>" (word "/var/log/myapp.log")))
---


# === Input ===

=== simple
cat < file.txt
---
(redirected (command (word "cat")) (redirect "<" (word "file.txt")))
---


=== simple no spaces
cat<file.txt
---
(redirected (command (word "cat")) (redirect "<" (word "file.txt")))
---


=== with arguments
wc -l < input.txt
---
(redirected (command (word "wc") (word "-l")) (redirect "<" (word "input.txt")))
---


=== sort from file
sort < unsorted.txt
---
(redirected (command (word "sort")) (redirect "<" (word "unsorted.txt")))
---


# === File descriptor ===

=== stderr
cmd 2> errors.txt
---
(redirected (command (word "cmd")) (redirect (fd 2) ">" (word "errors.txt")))
---


=== stderr append
cmd 2>> errors.txt
---
(redirected (command (word "cmd")) (redirect (fd 2) ">>" (word "errors.txt")))
---


=== stderr to dev null
cmd 2> /dev/null
---
(redirected (command (word "cmd")) (redirect (fd 2) ">" (word "/dev/null")))
---


=== stdout and stderr separate
cmd > out.txt 2> err.txt
---
(redirected (command (word "cmd")) (redirect ">" (word "out.txt")) (redirect (fd 2) ">" (word "err.txt")))
---


=== fd3
cmd 3> custom.txt
---
(redirected (command (word "cmd")) (redirect (fd 3) ">" (word "custom.txt")))
---


=== fd9
cmd 9> fd9.txt
---
(redirected (command (word "cmd")) (redirect (fd 9) ">" (word "fd9.txt")))
---


# === File descriptor duplication ===

=== stderr to stdout
cmd 2>&1
---
(redirected (command (word "cmd")) (redirect (fd 2) ">&" (fd 1)))
---


=== stdout to stderr
echo error >&2
---
(redirected (command (word "echo") (word "error")) (redirect ">&" (fd 2)))
---


=== stdout and stderr combined
cmd > out.txt 2>&1
---
(redirected (command (word "cmd")) (redirect ">" (word "out.txt")) (redirect (fd 2) ">&" (fd 1)))
---


=== stderr first then stdout
cmd 2>&1 > out.txt
---
(redirected (command (word "cmd")) (redirect (fd 2) ">&" (fd 1)) (redirect ">" (word "out.txt")))
---


# === Multiple ===

=== input and output
cmd < in.txt > out.txt
---
(redirected (command (word "cmd")) (redirect "<" (word "in.txt")) (redirect ">" (word "out.txt")))
---


=== three
cmd < in.txt > out.txt 2> err.txt
---
(redirected (command (word "cmd")) (redirect "<" (word "in.txt")) (redirect ">" (word "out.txt")) (redirect (fd 2) ">" (word "err.txt")))
---


=== before command args
< input.txt cat
---
(redirected (command (word "cat")) (redirect "<" (word "input.txt")))
---


=== between args
cat < input.txt -n
---
(redirected (command (word "cat") (word "-n")) (redirect "<" (word "input.txt")))
---


# === Here strings ===

=== simple
cat <<< "hello"
---
(redirected (command (word "cat")) (redirect "<<<" (word "\"hello\"")))
---


=== single quoted
cat <<< 'hello world'
---
(redirected (command (word "cat")) (redirect "<<<" (word "'hello world'")))
---


=== bare word
cat <<< hello
---
(redirected (command (word "cat")) (redirect "<<<" (word "hello")))
---


=== with fd
cat 0<<< "hello"
---
(redirected (command (word "cat")) (redirect (fd 0) "<<<" (word "\"hello\"")))
---


# === Special targets ===

=== path with spaces quoted
cmd > "/path/with spaces/file.txt"
---
(redirected (command (word "cmd")) (redirect ">" (word "\"/path/with spaces/file.txt\"")))
---


=== glob pattern
cmd > *.log
---
(redirected (command (word "cmd")) (redirect ">" (word "*.log")))
---


=== path with dots
cmd > ../output/file.txt
---
(redirected (command (word "cmd")) (redirect ">" (word "../output/file.txt")))
---


# === Tree sitter bash ===

=== at start
2>&1 whoami
---
(redirected (command (word "whoami")) (redirect (fd 2) ">&" (fd 1)))
---


=== stderr to stdout for echo
echo "foobar" >&2
---
(redirected (command (word "echo") (word "\"foobar\"")) (redirect ">&" (fd 2)))
---


# === Noclobber override ===

=== simple
whoami >| /dev/null
---
(redirected (command (word "whoami")) (redirect ">|" (word "/dev/null")))
---


# === Combined ===

=== to dev null
ls &>/dev/null
---
(redirected (command (word "ls")) (redirect "&>" (word "/dev/null")))
---


=== to file
cmd &> output.log
---
(redirected (command (word "cmd")) (redirect "&>" (word "output.log")))
---


=== append
cmd &>> output.log
---
(redirected (command (word "cmd")) (redirect "&>>" (word "output.log")))
---


# === Combined edge cases ===

=== no space
cmd &>file.log
---
(redirected (command (word "cmd")) (redirect "&>" (word "file.log")))
---


=== append no space
cmd &>>file.log
---
(redirected (command (word "cmd")) (redirect "&>>" (word "file.log")))
---


=== alternative form
cmd >& output.log
---
(redirected (command (word "cmd")) (redirect ">&" (word "output.log")))
---


=== alternative no space
cmd >&output.log
---
(redirected (command (word "cmd")) (redirect ">&" (word "output.log")))
---


=== with other redirect
cmd &> out.log < in.txt
---
(redirected (command (word "cmd")) (redirect "&>" (word "out.log")) (redirect "<" (word "in.txt")))
---


=== after other redirect
cmd < in.txt &> out.log
---
(redirected (command (word "cmd")) (redirect "<" (word "in.txt")) (redirect "&>" (word "out.log")))
---


=== before command
&> log.txt cmd
---
(redirected (command (word "cmd")) (redirect "&>" (word "log.txt")))
---


# === Close ===

=== stdout
cmd >&-
---
(redirected (command (word "cmd")) (redirect ">&" (close)))
---


=== stderr
cmd 2>&-
---
(redirected (command (word "cmd")) (redirect (fd 2) ">&" (close)))
---


=== stdin
cmd <&-
---
(redirected (command (word "cmd")) (redirect "<&" (close)))
---


=== fd3
cmd 3>&-
---
(redirected (command (word "cmd")) (redirect (fd 3) ">&" (close)))
---


=== input fd3
cmd 3<&-
---
(redirected (command (word "cmd")) (redirect (fd 3) "<&" (close)))
---


=== after dup
cmd 3>&1 3>&-
---
(redirected (command (word "cmd")) (redirect (fd 3) ">&" (fd 1)) (redirect (fd 3) ">&" (close)))
---


# === Move operations ===
# 
# Bash's `N<&M-`/`N>&M-` "move" a source fd into the target and close the source in one step.
# `M-` lexes as a single non-numeric word (the lexer has no notion of this suffix), so
# `parse_target` falls through to its `RedirectTarget::File` fallback rather than modeling the
# move/close semantics — not yet supported, tracked as a known gap rather than silently
# misparsed.

=== input
cmd 3<&0-
---
(redirected (command (word "cmd")) (redirect (fd 3) "<&" (word "0-")))
---


=== output
cmd 3>&1-
---
(redirected (command (word "cmd")) (redirect (fd 3) ">&" (word "1-")))
---


# === Complex ===

=== multiple combined
cmd &> out1.log 2>&1 &>> out2.log
---
(redirected (command (word "cmd")) (redirect "&>" (word "out1.log")) (redirect (fd 2) ">&" (fd 1)) (redirect "&>>" (word "out2.log")))
---


=== combined with here string
cmd &> log.txt <<< "input"
---
(redirected (command (word "cmd")) (redirect "&>" (word "log.txt")) (redirect "<<<" (word "\"input\"")))
---


=== combined in pipeline
cmd1 &> /dev/null | cmd2
---
(pipeline (redirected (command (word "cmd1")) (redirect "&>" (word "/dev/null"))) (| (command (word "cmd2"))))
---


=== combined in list with background
cmd1 &> log1.txt & cmd2 &> log2.txt
---
(bg (redirected (command (word "cmd1")) (redirect "&>" (word "log1.txt"))) (redirected (command (word "cmd2")) (redirect "&>" (word "log2.txt"))))
---


=== combined in and list
cmd1 &> log1.txt && cmd2 &> log2.txt
---
(and (redirected (command (word "cmd1")) (redirect "&>" (word "log1.txt"))) (redirected (command (word "cmd2")) (redirect "&>" (word "log2.txt"))))
---


=== combined with stderr dup
cmd 2>&1 &> file.log
---
(redirected (command (word "cmd")) (redirect (fd 2) ">&" (fd 1)) (redirect "&>" (word "file.log")))
---


=== combined in subshell
(cmd &> log.txt)
---
(subshell (redirected (command (word "cmd")) (redirect "&>" (word "log.txt"))))
---


=== combined in brace group
{ cmd &> log.txt; }
---
(brace-group (redirected (command (word "cmd")) (redirect "&>" (word "log.txt"))))
---


# === Read-write ===

# `<>` (InputOutput) is implemented in token_to_kind and parse_target but had zero corpus
# coverage. It opens the file for both reading and writing on the given fd (default: fd 0).

=== simple
cmd <> file
---
(redirected (command (word "cmd")) (redirect "<>" (word "file")))
---


=== with explicit fd 0
cmd 0<> file
---
(redirected (command (word "cmd")) (redirect (fd 0) "<>" (word "file")))
---


=== with non-zero fd
cmd 3<> scratch.tmp
---
(redirected (command (word "cmd")) (redirect (fd 3) "<>" (word "scratch.tmp")))
---


=== no spaces
cmd<>file
---
(redirected (command (word "cmd")) (redirect "<>" (word "file")))
---


=== with path
cmd <> /dev/tcp/host/port
---
(redirected (command (word "cmd")) (redirect "<>" (word "/dev/tcp/host/port")))
---


# === Duplicate input ===

# `<&N` (DuplicateInput) is implemented in parse_dup_target but coverage only existed for the
# close form (`<&-`). These cases test the non-close fd-target form.

=== stdin from fd 3
cmd <&3
---
(redirected (command (word "cmd")) (redirect "<&" (fd 3)))
---


=== stdin from fd 0
cmd <&0
---
(redirected (command (word "cmd")) (redirect "<&" (fd 0)))
---


=== with explicit fd prefix
cmd 0<&3
---
(redirected (command (word "cmd")) (redirect (fd 0) "<&" (fd 3)))
---


=== fd 4 from fd 1
cmd 4<&1
---
(redirected (command (word "cmd")) (redirect (fd 4) "<&" (fd 1)))
---


=== combined with output redirect
cmd <&3 > out.txt
---
(redirected (command (word "cmd")) (redirect "<&" (fd 3)) (redirect ">" (word "out.txt")))
---


# eof
