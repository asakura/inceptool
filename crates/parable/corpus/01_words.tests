#! Suite 1: Words

# === Basic ===

=== bare word
foo
---
(command (word "foo"))
---


=== with numbers
foo123
---
(command (word "foo123"))
---


=== with dash
foo-bar
---
(command (word "foo-bar"))
---


=== with underscore
foo_bar
---
(command (word "foo_bar"))
---


=== with dot
foo.bar
---
(command (word "foo.bar"))
---


=== with slash
/usr/bin
---
(command (word "/usr/bin"))
---


=== starting with number
123abc
---
(command (word "123abc"))
---


=== with all numbers
12345
---
(command (word "12345"))
---


=== with equal sign
foo=bar
---
(command (word "foo=bar"))
---


=== with colon char
foo:bar
---
(command (word "foo:bar"))
---


=== with at sign
foo@bar
---
(command (word "foo@bar"))
---


=== with percent sign
foo%bar
---
(command (word "foo%bar"))
---


=== with caret sign
foo^bar
---
(command (word "foo^bar"))
---


=== with plus sign
foo+bar
---
(command (word "foo+bar"))
---


=== with comma
foo,bar
---
(command (word "foo,bar"))
---


=== with tilde sign
~user
---
(command (word "~user"))
---


=== with question mark
foo?
---
(command (word "foo?"))
---


=== with asterisk
foo*
---
(command (word "foo*"))
---


=== with hash inside
foo#bar
---
(command (word "foo#bar"))
---


=== with brackets
foo[0]
---
(command (word "foo[0]"))
---


=== starting with relative path
./script.sh
---
(command (word "./script.sh"))
---


=== with parent path
../other/file
---
(command (word "../other/file"))
---


=== absolute path with dots
/foo/../bar/./baz
---
(command (word "/foo/../bar/./baz"))
---


# === Single quoted ===

=== empty
''
---
(command (word "''"))
---


=== simple
'hello'
---
(command (word "'hello'"))
---


=== with spaces
'hello world'
---
(command (word "'hello world'"))
---


=== with special chars
'$foo `cmd` \n'
---
(command (word "'$foo `cmd` \\n'"))
---


=== with double quotes inside
'say "hello"'
---
(command (word "'say \"hello\"'"))
---


=== adjacent single quoted
'foo''bar'
---
(command (word "'foo''bar'"))
---


# === Double quoted ===

=== empty
""
---
(command (word "\"\""))
---


=== simple
"hello"
---
(command (word "\"hello\""))
---


=== with spaces
"hello world"
---
(command (word "\"hello world\""))
---


=== containing single quotes
"it's fine"
---
(command (word "\"it's fine\""))
---


=== escaped quote
"say \"hello\""
---
(command (word "\"say \\\"hello\\\"\""))
---


=== escaped backslash
"path\\to\\file"
---
(command (word "\"path\\\\to\\\\file\""))
---


=== newline escape
"line1\nline2"
---
(command (word "\"line1\\nline2\""))
---


=== adjacent double quotes
"foo""bar"
---
(command (word "\"foo\"\"bar\""))
---


# === Mixed quotes ===

=== adjacent
'single'"double"
---
(command (word "'single'\"double\""))
---


=== unquoted and single quoted
foo'bar'baz
---
(command (word "foo'bar'baz"))
---


=== unquoted and double quoted
foo"bar"baz
---
(command (word "foo\"bar\"baz"))
---


=== complex combination
foo'bar'"baz"qux
---
(command (word "foo'bar'\"baz\"qux"))
---


# === Special parameters ===

# These single-character special-parameter forms are implemented in the lexer/word scanner but
# had zero corpus coverage. Each renders as a (word (special "X")), classified out of
# Expr::VarRef into its own Expr::SpecialParam variant.

=== all args
echo $@
---
(command (word "echo") (word (special "@")))
---


=== all args star
echo $*
---
(command (word "echo") (word (special "*")))
---


=== arg count
echo $#
---
(command (word "echo") (word (special "#")))
---


=== exit status
echo $?
---
(command (word "echo") (word (special "?")))
---


=== shell pid
echo $$
---
(command (word "echo") (word (special "$")))
---


=== last background pid
echo $!
---
(command (word "echo") (word (special "!")))
---


=== option flags
echo $-
---
(command (word "echo") (word (special "-")))
---


=== special param as part of interpolation
echo "pid=$$"
---
(command (word "echo") (word (interp "\"pid=" (special "$") "\"")))
---


=== multiple special params
echo $@ $# $?
---
(command (word "echo") (word (special "@")) (word (special "#")) (word (special "?")))
---


# === Braced variable references ===

# ${NAME} strips the braces in the AST (VarRef Display is "$NAME", not "${NAME}").
# ${NAME:-default} contains an operator inside the braces → not a plain parameter name →
# treated as an opaque Literal that preserves the full "${NAME:-default}" text verbatim.

=== simple brace
echo ${NAME}
---
(command (word "echo") (word (var "NAME")))
---


=== simple brace no space
echo ${FOO}
---
(command (word "echo") (word (var "FOO")))
---


=== brace strips to same as bare ref
echo ${VAR}
---
(command (word "echo") (word (var "VAR")))
---


=== default value operator is opaque literal
echo ${NAME:-default}
---
(command (word "echo") (word "${NAME:-default}"))
---


=== assign default operator is opaque literal
echo ${NAME:=default}
---
(command (word "echo") (word "${NAME:=default}"))
---


=== error operator is opaque literal
echo ${NAME:?error}
---
(command (word "echo") (word "${NAME:?error}"))
---


=== alternate value operator is opaque literal
echo ${NAME:+alt}
---
(command (word "echo") (word "${NAME:+alt}"))
---


=== length operator is opaque literal
echo ${#NAME}
---
(command (word "echo") (word "${#NAME}"))
---


# eof
